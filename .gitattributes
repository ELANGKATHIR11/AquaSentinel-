# AquaSentinel Git Attributes Configuration
# Configures Git LFS for approved assets between 10 MB and 100 MB.
# Broad tracking of multi-GB datasets or standard zip/hdf5 files in this file is prohibited.

# Approved small demo shapefiles & GeoJSON layers (10 MB - 100 MB)
data/demo/*.zip filter=lfs diff=lfs merge=lfs -text
data/demo/*.geojson filter=lfs diff=lfs merge=lfs -text

# Approved assets and maps under 100 MB
assets/wb_tn_shp.zip filter=lfs diff=lfs merge=lfs -text

# Approved model binaries under 100 MB
artifacts/models/*.joblib filter=lfs diff=lfs merge=lfs -text
artifacts/models/*.onnx filter=lfs diff=lfs merge=lfs -text

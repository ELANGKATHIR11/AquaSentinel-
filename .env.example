# =============================================================================
# AquaSentinel Platform — Environment Configuration Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Frontend (Vite) ---
# Base URL for the FastAPI REST API backend
VITE_API_BASE_URL=http://localhost:8000/api/v1
# WebSocket server URL
VITE_WS_URL=ws://localhost:8000/ws
# Set to "true" to run with offline mock data only (no backend required)
VITE_MOCK_MODE=false
# App version label shown in UI
VITE_APP_VERSION=1.0.0
# Deployment environment: development | staging | production
VITE_ENV=development

# --- Backend (FastAPI) ---
# PostgreSQL async connection URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@localhost:5432/aquasentinel
# Sync URL for Alembic migrations
DATABASE_URL_SYNC=postgresql+psycopg://postgres:CHANGE_ME@localhost:5432/aquasentinel
# Secret key for JWT signing (min 32 chars). Generate: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
# JWT token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Allowed environment for sensitive operations: development | production
APP_ENV=development

# --- MQTT ---
# Mosquitto broker host and port
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
# MQTT credentials (leave blank if broker has no auth configured)
MQTT_USERNAME=
MQTT_PASSWORD=
# MQTT topic prefix
MQTT_TOPIC_PREFIX=aquasentinel

# --- ML Model Registry ---
# Directory where trained joblib model files are stored
MODEL_REGISTRY_DIR=apps/api/models/registry

# --- Logging ---
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Log format: json | text
LOG_FORMAT=json
